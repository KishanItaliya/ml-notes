# ML Notes Agent – Environment Configuration
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# ── LLM Provider ──────────────────────────────
# Choose which model to use: "groq" (free) or "claude" (paid, better quality)
LLM_PROVIDER=groq

# ── API Keys (only the one matching your LLM_PROVIDER is required) ──
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ── GitHub ────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-username/ml-notes

# ── Output folders inside your GitHub repo ────
DOCS_FOLDER=docs
EXAMPLES_FOLDER=examples
